# Strava
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=
STRAVA_VERIFY_TOKEN=        # arbitrary secret string used when registering the webhook
STRAVA_ATHLETE_ID=          # numeric Strava athlete ID — only events from this athlete are processed

# Runner
RUNNER_NAME=                # athlete's first name — used for sheet tab resolution
RUNNER_WHATSAPP=            # E.164 format, e.g. +14379729046

# Google Sheets
GOOGLE_CREDENTIALS_PATH=credentials.json
SPREADSHEET_ID=

# Anthropic
ANTHROPIC_API_KEY=

# WhatsApp (Meta Cloud API)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
